[t:template,n:ann_r03_item_base]
{
	category_name = "1W_evil_d";
	doc = "ann_r03_helmet";
	specializes = dsx_zepheryl_base;

	aspect:	model		= <none>;
	aspect:	material	= steel;

	[common]
	{
		membership = gargoyle,monster;
	}
	[aspect]
	{
		experience_value = 37;
		force_no_render = true;
		life = 13;
		max_life = 13;
		mana = 8;
		max_mana = 8;
		draw_shadow = false;
		scale_base = 1;	 

		model = m_c_edm_ga_pos_1;

		[voice]
		{
			[die]			{ priority = high;	* = s_e_die_zepheryl_SED;		}
			[enemy_spotted]	{ priority = high; * = s_e_call_zepheryl_SED; }
			[hit_critical]	{ priority = low;	* = s_e_hit_zepheryl_SED;		}
			[hit_glance]	{ priority = low;	* = s_e_hit_zepheryl_SED;		}
			[hit_solid]		{ priority = low;	* = s_e_hit_zepheryl_SED;		}
		}
	}
	[actor]
	{
		[skills]
		{
			strength 		=	2, 0;
			intelligence 	=	 2, 0;
			dexterity 		=	2, 0;
			combat_magic 	=	2, 0;
			nature_magic 	=	2, 0;
				
		}
	}
	[attack]
	{
		attack_range = .5;
		damage_max = 10;
		damage_min = 3;
	}
	[common]
	{
		screen_name="Headseeker";
		membership = gargoyle, monster, immune_polymorph;
	}
	[defend] { 
		defense=14; 
	}
	[inventory]
	{
		selected_active_location = il_active_primary_spell;
		[other] { il_active_primary_spell=spell_zepheryl_zap; }
	}
	[mind]
	{
		actor_weapon_preference		= WP_MAGIC;
		actor_auto_switches_to_magic	= true;
		actor_auto_switches_to_karate	= false;
		actor_auto_switches_to_melee	= false;
	}
}





[t:template,n:ann_r03_possessed_helmet]
{
	category_name = "1W_evil_d";
	doc = "ann_r03_possessed_helmet";
	specializes = ann_r03_item_base;
	[common]
	{
		screen_name = "Vornhelm’s Helmet";
		[template_triggers]
		{
			[*]
				{
					action* = call_sfx_script("ann_flying_effect_helmet");
					condition* = receive_world_message("WE_ENTERED_WORLD");
					single_shot = true;
				}
		}
	}
}

