[t:template,n:ann_r03_toreck]
{
	category_name = "1W_evil_d";
	doc = "ann_r03_toreck";
	specializes = actor_evil;
	[actor]
	{
		[skills]
		{
			strength =  	2, 0;
			intelligence =  2, 0;
			dexterity =  	3, 0;
			melee =  		3, 0;
		}
	}
	[aspect]
	{
		experience_value = 44;
		life = 27;
		max_life = 27;
		mana = 14;
		max_mana = 14;
		model = m_c_ecm_to_pos_1;
		[voice]
		{
			[die]			{ priority = high; * = s_e_die_toreck; }
			[hit_critical]	{ priority = low; * = s_e_hit_toreck_SED; }
			[hit_glance]	{ priority = low; * = s_e_hit_toreck_SED; }
			[hit_solid]		{ priority = low; * = s_e_hit_toreck_SED; }
		}
		[textures]
		{
			0 = b_c_ecm_ann_toreck;
		}
	}
	[attack]
	{
		attack_range = 0.5;
		damage_max = 20;
		damage_min = 12;
	}
	[body]
	{
		avg_move_velocity = 2.340000;
		max_move_velocity = 3.7;
		[bone_translator]
		{
			body_anterior = bip01_head;
			body_mid = bip01_spine1;
			body_posterior = bip01_pelvis;
			kill_bone = bip01_spine1;
			shield_bone = shield_grip;
			weapon_bone = weapon_grip;
		}
		[chore_dictionary]
		{
			chore_prefix = a_c_ecm_to_fs;
			[chore_attack]
			{
				chore_stances = 5;
				skrit = select_attack;
				[anim_files]
					{
						00 = at;
						01 = at-02;
					}
			}
			[chore_default]
			{
				chore_stances = 5;
				skrit = infinite_loop;
				[anim_files] { 00=ds; }
			}
			[chore_die]
			{
				chore_stances = 5;
				skrit = select_transition;
				[anim_files] { 00=di; }
			}
			[chore_fidget]
			{
				chore_stances = 5;
				skrit = select_fidget;
				[anim_files] { 00=dff; }
			}
			[chore_walk]
			{
				chore_stances = 5;
				skrit = select_walk;
				[anim_files] { 00=wl; }
			}
		}
		[weapon_scales]
		{
			as_staff	= 1.8, 1.8, 1.8;
		}
	}
	[common] { screen_name="Soul Sweeper"; }
	[defend] { defense=44; }
   	[inventory]
	{
    	[pcontent]
		{
			[oneof*]
			{
				es_weapon_hand = ann_weapon_toreck;
			}
			[oneof*]
			{
				[oneof*]
				{
					chance = 0.35;
					il_main = #*/10-20;
					il_main = #armor/10-20;
				}
				[oneof*]
				{
	            	chance = 0.004;
	                il_main = #weapon/-rare(1)/12-25;
	                il_main = #armor/-rare(1)/15-30;
                    il_main = #*/-rare(1)/12-20;
                }
				[oneof*]
				{
                	chance = 0.002;
	                il_main = #weapon/-unique(2)/12-15;
	                il_main = #armor/-unique(2)/20-25;
                    il_main = #*/-unique(2)/12-15;
	            }
				[gold*]
				{
					chance = 0.125;
					max = 60;
					min = 30;
				}
    		}
		}
	}
	[mind]
	{
		jat_attack_object_melee 			= world\ai\jobs\common\job_attack_object_melee.skrit
			?run_chance 					= 1.0;
		jat_fidget							= world\ai\jobs\common\job_fidget.skrit
			?curious							= 0.75
			&interest							= interest
			&meander							= false
			&still								= false;

		melee_engage_range = 14;
		personal_space_range = 0.7;
		ranged_engage_range = 14.0;
		sight_range = 14.0;
	}
}

[t:template,n:ann_r03_vampire_male]
{
	category_name = "1W_evil_d";
	doc = "ann_r03_vampire_male";
	specializes = base_bandit;
	[actor]
	{
		[skills]
		{
			dexterity 		= 0.51, 0, 10;
			intelligence 	= 2.1, 0, 10;
			strength 		= 0.39, 0, 10;
			melee 	= 4,0,0;
		}
	}
	[aspect]
	{
		experience_value = 44;
		life = 27;
		max_life = 27;
		mana = 14;
		max_mana = 14;
