		{
			0 = b_c_gah_fb_vampire_skin;
			1 = b_c_pos_a7_vampire_armor;
		}
	}
	[common]
	{
		membership = monster, party_bandit_ranged, bandit;
		screen_name = "Vlad";
	}
	[inventory]
	{
		[pcontent]
		{
			[all*]
			{
				es_feet = bo_bo_le_light;
                es_weapon_hand = ann_weapon_vampire;
			}
			[oneof*]
			{
				[oneof*]
				{
				   chance = 0.05;
				   il_main = potion_health_medium;
				   il_main = potion_mana_medium;
				}
				[all*]
				{
       				chance = 0.02;
	                il_main = #spell/8-12;
				}
				[oneof*]
				{
					chance = 0.22;
					il_main = #*/12-24;
					il_main = #armor/15-19;
				}
                [oneof*]
				{
	            	chance = 0.004;
	                il_main = #weapon/-rare(1)/34-40;
	                il_main = #armor/-rare(1)/30-42;
                    il_main = #*/-rare(1)/34-40;
                }
				[oneof*]
				{
                	chance = 0.002;
	                il_main = #weapon/-unique(2)/30-40;
	                il_main = #armor/-unique(2)/30-40;
                    il_main = #*/-unique(2)/30-40;
	            }
				[gold*]
				{
					chance = 0.125;
					max = 40;
					min = 20;
				}
			}
		}
	}
	[attack]
	{
		attack_range = 0.5;
		damage_max = 20;
		damage_min = 12;
	}
   	[defend] { defense=40; }
   	[mind]
   	{
		jat_brain						= world\ai\jobs\common\brain_hero.skrit
			?actor_joins_existing_party	= true;
		jat_fidget		= world\ai\jobs\common\job_fidget.skrit
			?curious		= 0.75
			&interest		= interest
			&meander		= true
			&still			= false;
	}
	[ann_spawn_on_death]
	{
		spawn_template = ann_bat_volatile;
		spawn_count = 8;
		minDistance = 0.1;
		maxDistance = 0.3;
	}
}

