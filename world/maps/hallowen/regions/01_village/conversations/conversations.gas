[shop_potions]
{
	[text*]
	{
		choice = shop;
		screen_text = "My name is Tender... Bat Tender! Whether you're about to face that cursed fog, or you just survived it, you look like you need a strong drink. I've got health 'juice' and mana tonics. Gold first, heroism later!";
	  f scroll_rate = 10.000000;
	}
