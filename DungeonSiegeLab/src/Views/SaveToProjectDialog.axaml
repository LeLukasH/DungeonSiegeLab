<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DungeonSiegeLab.ViewModels"
        x:Class="DungeonSiegeLab.Views.SaveToProjectDialog"
        x:DataType="vm:SaveToProjectViewModel"
        Title="Save to Project"
        Width="480" Height="280"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="BorderOnly">

    <Border Padding="24" Background="#1e1e2e">
        <StackPanel Spacing="16">

            <TextBlock Text="Save Texture to Project"
                       FontSize="16" FontWeight="Bold"
                       Foreground="#cdd6f4"/>

            <StackPanel Spacing="4">
                <TextBlock Text="Relative path in /Bits:"
                           Foreground="#a6adc8" FontSize="12"/>
                <TextBox Text="{Binding RelativePath}"
                         FontFamily="Consolas,monospace"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Texture name (without extension):"
                           Foreground="#a6adc8" FontSize="12"/>
                <TextBox Text="{Binding TextureName}"
                         FontFamily="Consolas,monospace"/>
            </StackPanel>

            <Border Background="#181825" CornerRadius="4" Padding="10 6">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="{Binding IsStatusOk,
                             Converter={StaticResource BoolToBrushConverter},
                             ConverterParameter='#a6e3a1|#f38ba8'}"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Classes="secondary"
                        Command="{Binding CancelCommand}"/>
                <Button Content="💾 Export to Project"
                        Classes="primary"
                        Command="{Binding ExportToProjectCommand}"
                        IsEnabled="{Binding !IsSaving}"/>
            </StackPanel>

        </StackPanel>
    </Border>

</Window>
