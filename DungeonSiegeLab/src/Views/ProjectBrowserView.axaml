<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonSiegeLab.ViewModels"
             x:Class="DungeonSiegeLab.Views.ProjectBrowserView"
             x:DataType="vm:ProjectBrowserViewModel">

    <UserControl.Styles>
        <!-- Sidebar tab toggle buttons -->
        <Style Selector="Button.sidebarTab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0 0 0 2"/>
            <Setter Property="Padding" Value="12 6"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Foreground" Value="#585b70"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.sidebarTab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#252537"/>
        </Style>
        <Style Selector="Button.sidebarTab.active">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#cba6f7"/>
        </Style>
    </UserControl.Styles>

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="#181825"
                Padding="10 8"
                BorderBrush="#313244"
                BorderThickness="0 0 0 1">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0 0 16 0">
                    <TextBlock Text="📂 /Bits:" VerticalAlignment="Center" Foreground="#a6adc8"/>
                    <TextBox Text="{Binding BitsPath}"
                             Width="300" Height="30"
                             IsReadOnly="True"
                             Watermark="No folder loaded…"
                             VerticalContentAlignment="Center"/>
                    <!-- Split Browse button: main action + recent dropdown arrow -->
                    <StackPanel Orientation="Horizontal" Spacing="0">
                        <Button Content="Browse…"
                                Classes="secondary"
                                Height="30"
                                CornerRadius="4 0 0 4"
                                Click="OnBrowseClicked"/>
                        <Button Classes="secondary"
                                Height="30"
                                Width="26"
                                Padding="0"
                                FontSize="11"
                                CornerRadius="0 4 4 0"
                                BorderThickness="0 1 1 1"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                IsVisible="{Binding HasRecentPaths}"
                                Click="OnOpenRecentClicked">▼</Button>
                    </StackPanel>
                </StackPanel>

                <Separator Width="1" Height="24" Background="#45475a" Margin="0 0 16 0"/>

                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="🔍 Identify"
                            Classes="primary"
                            Height="30"
                            Command="{Binding IdentifyCommand}"
                            IsEnabled="{Binding CanIdentify}"
                            ToolTip.Tip="Finds all dependencies (textures, templates, sounds, effects, scripts) of the selected template"/>
                </StackPanel>

                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}"
                             Width="80" Height="4"
                             Margin="16 0 0 0"
                             VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#11111b"
                Padding="12 4"
                BorderBrush="#313244"
                BorderThickness="0 1 0 0">
            <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#a6adc8"
                           FontSize="12"/>
                <TextBlock Text="{Binding StatusDetail}"
                           Foreground="#45475a"
                           FontSize="12"
                           IsVisible="{Binding StatusDetail, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
            </StackPanel>
        </Border>

        <!-- Main content: left panel | splitter | code viewer -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding IsDependencyPanelOpen, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=4}"/>
                <ColumnDefinition Width="{Binding IsDependencyPanelOpen, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=300}"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel -->
            <Border Grid.Column="0"
                    Background="#1e1e2e"
                    BorderBrush="#313244"
                    BorderThickness="0 0 1 0">
                <DockPanel>

                    <!-- Explorer / Search toggle -->
                    <Border DockPanel.Dock="Top"
                            Background="#181825"
                            BorderBrush="#313244"
                            BorderThickness="0 0 0 1">
                        <StackPanel Orientation="Horizontal">
                            <Button Classes="sidebarTab"
                                    Classes.active="{Binding !IsSearchPanelActive}"
                                    Command="{Binding ShowExplorerCommand}"
                                    ToolTip.Tip="Explorer">
                                Explorer
                            </Button>
                            <Button Classes="sidebarTab"
                                    Classes.active="{Binding IsSearchPanelActive}"
                                    Command="{Binding ShowSearchCommand}"
                                    ToolTip.Tip="Search templates">
                                🔍 Search
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- ── Explorer / Search (shared fill cell) ── -->
                    <Grid>

                    <!-- ── Explorer ── -->
                    <ScrollViewer IsVisible="{Binding !IsSearchPanelActive}"
                                  HorizontalScrollBarVisibility="Auto"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch">
                        <StackPanel HorizontalAlignment="Stretch">

                            <!-- Bits tree -->
                            <TreeView x:Name="BitsTreeView"
                                      ItemsSource="{Binding BitsRootNodes}"
                                      SelectedItem="{Binding SelectedNode}"
                                      Margin="4"
                                      HorizontalAlignment="Stretch"
                                      DoubleTapped="OnTreeDoubleTapped">
                                <TreeView.Styles>
                                    <Style Selector="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    </Style>
                                </TreeView.Styles>
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType="vm:BitsComponentViewModel"
                                                      ItemsSource="{Binding Children}">
                                        <Border HorizontalAlignment="Stretch" Background="Transparent">
                                            <StackPanel Orientation="Horizontal" Spacing="5" Margin="0 2">
                                                <TextBlock Text="{Binding Icon}" FontSize="13"/>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13"
                                                           Foreground="{Binding NodeColor}"/>
                                            </StackPanel>
                                        </Border>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>

                            <!-- Divider -->
                            <StackPanel IsVisible="{Binding HasUntankSection}" Margin="0 4 0 0">
                                <Border Height="1" Background="#313244" Margin="8 0"/>
                                <TextBlock Text="UNTANK"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           Foreground="#45475a"
                                           Margin="12 4 0 2"
                                           LetterSpacing="1.5"/>
                            </StackPanel>

                            <!-- Untank tree — faded -->
                            <TreeView x:Name="UntankTreeView"
                                      ItemsSource="{Binding UntankRootNodes}"
                                      SelectedItem="{Binding SelectedNode}"
                                      Margin="4"
                                      Opacity="0.6"
                                      HorizontalAlignment="Stretch"
                                      DoubleTapped="OnTreeDoubleTapped">
                                <TreeView.Styles>
                                    <Style Selector="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    </Style>
                                </TreeView.Styles>
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType="vm:BitsComponentViewModel"
                                                      ItemsSource="{Binding Children}">
                                        <Border HorizontalAlignment="Stretch" Background="Transparent">
                                            <StackPanel Orientation="Horizontal" Spacing="5" Margin="0 2">
                                                <TextBlock Text="{Binding Icon}" FontSize="13"/>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13"
                                                           Foreground="{Binding NodeColor}"/>
                                            </StackPanel>
                                        </Border>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- ── Search ── -->
                    <DockPanel IsVisible="{Binding IsSearchPanelActive}">

                        <!-- Search controls -->
                        <Border DockPanel.Dock="Top" Padding="8">
                        <StackPanel Spacing="6">
                            <TextBox Text="{Binding SearchQuery}"
                                     Watermark="Search…"
                                     Height="30"
                                     VerticalContentAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <CheckBox Content="Names"
                                          IsChecked="{Binding SearchInNames}"
                                          FontSize="12"
                                          Foreground="#a6adc8"/>
                                <CheckBox Content="Content"
                                          IsChecked="{Binding SearchInContent}"
                                          FontSize="12"
                                          Foreground="#a6adc8"/>
                                <ProgressBar IsIndeterminate="True"
                                             IsVisible="{Binding IsSearching}"
                                             Width="40" Height="3"
                                             VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SearchStatusMessage}"
                                       FontSize="11"
                                       Foreground="#6c7086"/>
                        </StackPanel>
                        </Border>

                        <!-- Results list -->
                        <ScrollViewer>
                            <ListBox ItemsSource="{Binding SearchResults}"
                                     SelectedItem="{Binding SelectedSearchResult}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     DoubleTapped="OnSearchResultDoubleTapped">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="8 6"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#252537"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#313244"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="vm:SearchResultViewModel">
                                        <StackPanel Spacing="0">

                                            <!-- Divider before first Untank result -->
                                            <StackPanel IsVisible="{Binding IsFirstUntankResult}"
                                                        Margin="-8 0 -8 6">
                                                <Border Height="1" Background="#313244"/>
                                                <TextBlock Text="UNTANK"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#45475a"
                                                           Margin="8 4 0 0"
                                                           LetterSpacing="1.5"/>
                                            </StackPanel>

                                            <!-- Result content -->
                                            <StackPanel Spacing="1">
                                                <ItemsControl ItemsSource="{Binding HighlightedName}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="vm:SnippetSpan">
                                                            <Border Background="{Binding Background}" CornerRadius="2">
                                                                <TextBlock Text="{Binding Text}"
                                                                           FontSize="13"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{Binding NameForeground}"/>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="{Binding RelativePath}"
                                                           FontSize="11"
                                                           Foreground="#6c7086"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <!-- Highlighted snippets: one row per line, spans per match -->
                                                <ItemsControl ItemsSource="{Binding HighlightedSnippets}"
                                                              IsVisible="{Binding HasSnippet}"
                                                              Margin="0 2 0 0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <ItemsControl ItemsSource="{Binding}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel Orientation="Horizontal"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate DataType="vm:SnippetSpan">
                                                                        <Border Background="{Binding Background}"
                                                                                CornerRadius="2">
                                                                            <TextBlock Text="{Binding Text}"
                                                                                       FontSize="11"
                                                                                       Foreground="{Binding Foreground}"
                                                                                       FontFamily="Cascadia Code,Consolas,monospace"/>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>

                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>

                    </DockPanel>

                    </Grid><!-- end Explorer/Search grid -->

                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Background="#313244"
                          ResizeDirection="Columns"/>

            <!-- Code viewer with VSCode-style tabs -->
            <Grid Grid.Column="2" Background="#1e1e2e">

                <TextBlock IsVisible="{Binding HasNoOpenCodeTabs}"
                           Text="Click a template in the tree…"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#6c7086"
                           FontSize="14"/>

                <TabControl IsVisible="{Binding HasOpenCodeTabs}"
                            ItemsSource="{Binding OpenCodeTabs}"
                            SelectedItem="{Binding SelectedCodeTab}">

                    <TabControl.Styles>
                        <Style Selector="TabItem">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="8 4"/>
                            <Setter Property="MinHeight" Value="0"/>
                        </Style>
                    </TabControl.Styles>

                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="vm:CodeTabViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="4"
                                        DoubleTapped="OnTabHeaderDoubleTapped">
                                <TextBlock Text="{Binding Name}"
                                           FontStyle="{Binding IsPreview,
                                             Converter={StaticResource BoolToFontStyleConverter}}"
                                           VerticalAlignment="Center"/>
                                <Button Content="✕"
                                        Width="16" Height="16"
                                        Padding="0"
                                        FontSize="9"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        VerticalContentAlignment="Center"
                                        HorizontalContentAlignment="Center"
                                        Click="OnCloseCodeTabClicked"/>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>

                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="vm:CodeTabViewModel">     
                            <!-- Code -->
                            <ScrollViewer HorizontalScrollBarVisibility="Auto">
                                <TextBox Text="{Binding SourceCode}"
                                        IsReadOnly="True"
                                        FontFamily="Cascadia Code,Consolas,monospace"
                                        FontSize="13"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="16"
                                        TextWrapping="NoWrap"
                                        AcceptsReturn="True"/>
                            </ScrollViewer>    
                        </DataTemplate>
                    </TabControl.ContentTemplate>

                </TabControl>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="3"
                          IsVisible="{Binding IsDependencyPanelOpen}"
                          Background="#313244"
                          ResizeDirection="Columns"/>

            <Border Grid.Column="4"
                    IsVisible="{Binding IsDependencyPanelOpen}"
                    Background="#181825"
                    BorderBrush="#313244"
                    BorderThickness="1 0 0 0"
                    Padding="8">

                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Header -->
                    <TextBlock Text="Dependencies"
                            FontWeight="Bold"
                            Foreground="#cdd6f4"
                            Margin="4"/>

                    <!-- List -->
                    <ListBox ItemsSource="{Binding IdentifiedDependencies}"
                            SelectedItem="{Binding SelectedIdentifiedDependency}"
                            Background="Transparent"
                            BorderThickness="0">

                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.Styles>

                        <ListBox.ItemTemplate>
                            <DataTemplate>

                                <Border Padding="6" Margin="2"
                                        Background="#1e1e2e"
                                        CornerRadius="4">

                                    <StackPanel Spacing="2">

                                        <!-- Value -->
                                        <TextBlock Text="{Binding Value, StringFormat='Value: {0}'}"
                                                Foreground="#cba6f7"
                                                FontWeight="SemiBold"/>

                                        <!-- Kind + Origin -->
                                        <StackPanel Orientation="Horizontal" Spacing="6">

                                            <TextBlock Text="{Binding Kind, StringFormat='Kind: {0}'}"
                                                    Foreground="#89b4fa"
                                                    FontSize="11"/>

                                            <TextBlock Text="{Binding Origin, StringFormat='Origin: {0}'}"
                                                    FontSize="11"
                                                    Foreground="#f38ba8"
                                                    IsVisible="{Binding IsInherited}"/>
                                        </StackPanel>

                                        <!-- Source -->
                                        <TextBlock Text="{Binding SourcePath, StringFormat='SourcePath: {0}'}"
                                                FontSize="11"
                                                Foreground="#6c7086"
                                                TextTrimming="CharacterEllipsis"/>

                                    </StackPanel>
                                </Border>

                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>
    </DockPanel>

</UserControl>
