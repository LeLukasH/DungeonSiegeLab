<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DungeonSiegeLab.ViewModels"
             x:Class="DungeonSiegeLab.Views.ProjectBrowserView"
             x:DataType="vm:ProjectBrowserViewModel">

    <UserControl.Styles>
        <!-- Sidebar tab toggle buttons -->
        <Style Selector="Button.sidebarTab">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0 0 0 2"/>
            <Setter Property="Padding" Value="12 6"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Foreground" Value="#585b70"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style Selector="Button.sidebarTab:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#252537"/>
        </Style>
        <Style Selector="Button.sidebarTab.active">
            <Setter Property="Foreground" Value="#cdd6f4"/>
            <Setter Property="BorderBrush" Value="#cba6f7"/>
        </Style>
    </UserControl.Styles>

    <DockPanel>

        <!-- Toolbar -->
        <Border DockPanel.Dock="Top"
                Background="#181825"
                Padding="10 8"
                BorderBrush="#313244"
                BorderThickness="0 0 0 1">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0 0 16 0">
                    <TextBlock Text="📂 /Bits:" VerticalAlignment="Center" Foreground="#a6adc8"/>
                    <TextBox Text="{Binding BitsPath}"
                             Width="300" Height="30"
                             Watermark="Path to /Bits folder..."
                             VerticalContentAlignment="Center"/>
                    <Button Content="Browse..."
                            Classes="secondary"
                            Height="30"
                            Click="OnBrowseClicked"/>
                    <Button Content="Load"
                            Classes="primary"
                            Height="30"
                            Command="{Binding LoadBitsFolderCommand}"
                            CommandParameter="{Binding BitsPath}"/>
                </StackPanel>

                <Separator Width="1" Height="24" Background="#45475a" Margin="0 0 16 0"/>

                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Content="🔍 Identify"
                            Classes="primary"
                            Height="30"
                            Command="{Binding IdentifyCommand}"
                            ToolTip.Tip="Finds all dependencies (textures, templates, sounds, effects, scripts) of the selected template"/>
                </StackPanel>

                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}"
                             Width="80" Height="4"
                             Margin="16 0 0 0"
                             VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom"
                Background="#11111b"
                Padding="12 4"
                BorderBrush="#313244"
                BorderThickness="0 1 0 0">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="#a6adc8"
                       FontSize="12"/>
        </Border>

        <!-- Main content: left panel | splitter | code viewer -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="150"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="{Binding IsDependencyPanelOpen, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=4}"/>
                <ColumnDefinition Width="{Binding IsDependencyPanelOpen, Converter={StaticResource BoolToGridLengthConverter}, ConverterParameter=300}"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel -->
            <Border Grid.Column="0"
                    Background="#1e1e2e"
                    BorderBrush="#313244"
                    BorderThickness="0 0 1 0">
                <DockPanel>

                    <!-- Explorer / Search toggle -->
                    <Border DockPanel.Dock="Top"
                            Background="#181825"
                            BorderBrush="#313244"
                            BorderThickness="0 0 0 1">
                        <StackPanel Orientation="Horizontal">
                            <Button Classes="sidebarTab"
                                    Classes.active="{Binding !IsSearchPanelActive}"
                                    Command="{Binding ShowExplorerCommand}"
                                    ToolTip.Tip="Explorer">
                                Explorer
                            </Button>
                            <Button Classes="sidebarTab"
                                    Classes.active="{Binding IsSearchPanelActive}"
                                    Command="{Binding ShowSearchCommand}"
                                    ToolTip.Tip="Search templates">
                                🔍 Search
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- ── Explorer ── -->
                    <DockPanel IsVisible="{Binding !IsSearchPanelActive}">
                        <ScrollViewer>
                            <TreeView ItemsSource="{Binding RootNodes}"
                                      SelectedItem="{Binding SelectedNode}"
                                      Margin="4"
                                      DoubleTapped="OnTreeDoubleTapped">
                                <TreeView.Styles>
                                    <Style Selector="TreeViewItem">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    </Style>
                                </TreeView.Styles>
                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate DataType="vm:BitsNodeViewModel"
                                                      ItemsSource="{Binding Children}">
                                        <Border HorizontalAlignment="Stretch"
                                                Background="Transparent"
                                                Tapped="OnTreeItemTapped">
                                            <StackPanel Orientation="Horizontal" Spacing="5" Margin="0 2">
                                                <TextBlock Text="{Binding Icon}" FontSize="13"/>
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="13"
                                                           Foreground="{Binding IsTemplate,
                                                             Converter={StaticResource BoolToBrushConverter},
                                                             ConverterParameter='#cba6f7|#cdd6f4'}"/>
                                            </StackPanel>
                                        </Border>
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- ── Search ── -->
                    <DockPanel IsVisible="{Binding IsSearchPanelActive}">

                        <!-- Search controls -->
                        <Border DockPanel.Dock="Top" Padding="8">
                        <StackPanel Spacing="6">
                            <TextBox Text="{Binding SearchQuery}"
                                     Watermark="Search…"
                                     Height="30"
                                     VerticalContentAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <CheckBox Content="Names"
                                          IsChecked="{Binding SearchInNames}"
                                          FontSize="12"
                                          Foreground="#a6adc8"/>
                                <CheckBox Content="Content"
                                          IsChecked="{Binding SearchInContent}"
                                          FontSize="12"
                                          Foreground="#a6adc8"/>
                                <ProgressBar IsIndeterminate="True"
                                             IsVisible="{Binding IsSearching}"
                                             Width="40" Height="3"
                                             VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SearchStatusMessage}"
                                       FontSize="11"
                                       Foreground="#6c7086"/>
                        </StackPanel>
                        </Border>

                        <!-- Results list -->
                        <ScrollViewer>
                            <ListBox ItemsSource="{Binding SearchResults}"
                                     SelectedItem="{Binding SelectedSearchResult}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     DoubleTapped="OnSearchResultDoubleTapped">
                                <ListBox.Styles>
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Padding" Value="8 6"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#252537"/>
                                    </Style>
                                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                        <Setter Property="Background" Value="#313244"/>
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="vm:SearchResultViewModel">
                                        <StackPanel Spacing="1">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="#cba6f7"/>
                                            <TextBlock Text="{Binding RelativePath}"
                                                       FontSize="11"
                                                       Foreground="#6c7086"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding MatchSnippet}"
                                                       IsVisible="{Binding HasSnippet}"
                                                       FontSize="11"
                                                       Foreground="#89b4fa"
                                                       FontFamily="Cascadia Code,Consolas,monospace"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0 2 0 0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>

                    </DockPanel>

                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1"
                          Background="#313244"
                          ResizeDirection="Columns"/>

            <!-- Code viewer with VSCode-style tabs -->
            <Grid Grid.Column="2" Background="#1e1e2e">

                <TextBlock IsVisible="{Binding HasNoOpenCodeTabs}"
                           Text="Click a template in the tree…"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#6c7086"
                           FontSize="14"/>

                <TabControl IsVisible="{Binding HasOpenCodeTabs}"
                            ItemsSource="{Binding OpenCodeTabs}"
                            SelectedItem="{Binding SelectedCodeTab}">

                    <TabControl.Styles>
                        <Style Selector="TabItem">
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="8 4"/>
                            <Setter Property="MinHeight" Value="0"/>
                        </Style>
                    </TabControl.Styles>

                    <TabControl.ItemTemplate>
                        <DataTemplate DataType="vm:CodeTabViewModel">
                            <StackPanel Orientation="Horizontal" Spacing="4"
                                        DoubleTapped="OnTabHeaderDoubleTapped">
                                <TextBlock Text="{Binding Name}"
                                           FontStyle="{Binding IsPreview,
                                             Converter={StaticResource BoolToFontStyleConverter}}"
                                           VerticalAlignment="Center"/>
                                <Button Content="✕"
                                        Width="16" Height="16"
                                        Padding="0"
                                        FontSize="9"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        VerticalContentAlignment="Center"
                                        HorizontalContentAlignment="Center"
                                        Click="OnCloseCodeTabClicked"/>
                            </StackPanel>
                        </DataTemplate>
                    </TabControl.ItemTemplate>

                    <TabControl.ContentTemplate>
                        <DataTemplate DataType="vm:CodeTabViewModel">
                            <Grid>
                            
                                <!-- Code -->
                                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                                    <TextBox Text="{Binding SourceCode}"
                                            IsReadOnly="True"
                                            FontFamily="Cascadia Code,Consolas,monospace"
                                            FontSize="13"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="16"
                                            TextWrapping="NoWrap"
                                            AcceptsReturn="True"/>
                                </ScrollViewer>

                                <!-- Dots - the next step, not functional --> 
                                <!-- <ItemsControl   ItemsSource="{Binding Dependencies}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Width="10"
                                                    Height="10"
                                                    Background="#89b4fa"
                                                    BorderThickness="0"
                                                    ToolTip.Tip="{Binding DisplayText}"
                                                    Command="{Binding DataContext.OpenDependencyCommand,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">

                                                <Canvas.Left>4</Canvas.Left>

                                                <Canvas.Top>
                                                    <Binding Path="Line" Converter="{StaticResource LineToYConverter}"/>
                                                </Canvas.Top>

                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl> -->
                                

                                <!-- DOT (collapsed state) -->
                                
                                <Button Width="12"
                                        Height="12"
                                        CornerRadius="6"
                                        Background="#ffffff"
                                        BorderThickness="0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,8,8,0"
                                        ToolTip.Tip="Show status"
                                        IsVisible="{Binding !IsStatusExpanded}"
                                        Command="{Binding ToggleStatusCommand}"/>
                                
                                <!-- PANEL (expanded state) -->
                                <Border IsVisible="{Binding IsStatusExpanded}"
                                        Background="#181825"
                                        BorderBrush="#313244"
                                        BorderThickness="1"
                                        Width="260"
                                        Padding="10"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,8,8,0"
                                        ZIndex="10">

                                    <StackPanel Spacing="8">

                                        <TextBlock Text="Status"
                                                FontWeight="Bold"
                                                Foreground="#cdd6f4"
                                                FontSize="12"/>

                                        <ScrollViewer MaxHeight="200">
                                            <TextBlock Text="{Binding DataContext.StatusMessage,
                                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    TextWrapping="Wrap"
                                                    Foreground="#a6adc8"
                                                    FontSize="12"/>
                                        </ScrollViewer>

                                        <Button Content="Close"
                                                Classes="secondary"
                                                Command="{Binding ToggleStatusCommand}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </TabControl.ContentTemplate>

                </TabControl>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="3"
                          IsVisible="{Binding IsDependencyPanelOpen}"
                          Background="#313244"
                          ResizeDirection="Columns"/>

            <Border Grid.Column="4"
                    IsVisible="{Binding IsDependencyPanelOpen}"
                    Background="#181825"
                    BorderBrush="#313244"
                    BorderThickness="1 0 0 0"
                    Padding="8">

                <ScrollViewer HorizontalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Header -->
                    <TextBlock Text="Dependencies"
                            FontWeight="Bold"
                            Foreground="#cdd6f4"
                            Margin="4"/>

                    <!-- List -->
                    <ListBox ItemsSource="{Binding IdentifiedDependencies}"
                            SelectedItem="{Binding SelectedIdentifiedDependency}"
                            Background="Transparent"
                            BorderThickness="0">

                        <ListBox.ItemTemplate>
                            <DataTemplate>

                                <Border Padding="6" Margin="2"
                                        Background="#1e1e2e"
                                        CornerRadius="4">

                                    <StackPanel Spacing="2">

                                        <!-- Value -->
                                        <TextBlock Text="{Binding Value, StringFormat='Value: {0}'}"
                                                Foreground="#cba6f7"
                                                FontWeight="SemiBold"/>

                                        <!-- Kind + Origin -->
                                        <StackPanel Orientation="Horizontal" Spacing="6">

                                            <TextBlock Text="{Binding Kind, StringFormat='Kind: {0}'}"
                                                    Foreground="#89b4fa"
                                                    FontSize="11"/>

                                            <TextBlock Text="{Binding Origin, StringFormat='Origin: {0}'}"
                                                    FontSize="11"
                                                    Foreground="#f38ba8"
                                                    IsVisible="{Binding IsInherited}"/>
                                        </StackPanel>

                                        <!-- Source -->
                                        <TextBlock Text="{Binding SourcePath, StringFormat='SourcePath: {0}'}"
                                                FontSize="11"
                                                Foreground="#6c7086"
                                                TextTrimming="CharacterEllipsis"/>

                                    </StackPanel>
                                </Border>

                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </StackPanel>
                </ScrollViewer>
            </Border>

        </Grid>
    </DockPanel>

</UserControl>
