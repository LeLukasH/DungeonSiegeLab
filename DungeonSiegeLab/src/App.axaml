<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:DungeonSiegeLab.Views"
             x:Class="DungeonSiegeLab.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <conv:BoolToBrushConverter x:Key="BoolToBrushConverter"/>
        <conv:BoolToFontStyleConverter x:Key="BoolToFontStyleConverter"/>
        <conv:StatusToBrushConverter x:Key="StatusToBrushConverter"/>
        <conv:BoolToGridLengthConverter x:Key="BoolToGridLengthConverter"/>
        <conv:LineToYConverter x:Key="LineToYConverter"/>
    </Application.Resources>

</Application>
